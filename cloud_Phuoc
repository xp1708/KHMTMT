BLYNK_AUTH_TOKEN = "Ii8HYbZFetp15zyfJ47NGgeCE0ErknkO"
# Sử dụng thư viện gpiozero để định nghĩa LED ở chân GPIO 17
led = LED(17) 

# Khởi tạo Blynk
blynk = blynklib.Blynk(BLYNK_AUTH_TOKEN)

# Hàm xử lý khi nhấn Switch trên Blynk (V0)
@blynk.on("V0")
def v0_write_handler(value):
    # value là một list, lấy phần tử đầu tiên
    state = int(value[0])
    if state == 1:
        led.on()  # Bật LED bằng gpiozero
        print("Trạng thái: LED BẬT")
    else:
        led.off() # Tắt LED bằng gpiozero
        print("Trạng thái: LED TẮT")

print("Đang kết nối tới Blynk Cloud...")

# Vòng lặp chính
try:
    while True:
        blynk.run()
except KeyboardInterrupt:
