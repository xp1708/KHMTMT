THAY BẰNG ĐOẠN NÀY
import blynklib

print("[BLYNK] Dang khoi tao ket noi...")

BLYNK_SERVER = "blynk.cloud"

try:
    blynk = blynklib.Blynk(
        BLYNK_AUTH_TOKEN,
        server=BLYNK_SERVER,
        port=80
    )

    print("[BLYNK] Da tao client")

    # test kết nối
    timeout = time.time() + 10
    connected = False

    while time.time() < timeout:
        blynk.run()
        time.sleep(0.1)

        try:
            if blynk.connected():
                connected = True
                break
        except:
            pass

    if connected:
        print("[BLYNK] Ket noi thanh cong")
        blynk_enabled = True
    else:
        print("[BLYNK] Timeout ket noi")
        blynk_enabled = False
        blynk = None

except Exception as e:
    print(f"[BLYNK ERROR] {e}")
    blynk_enabled = False
    blynk = None
