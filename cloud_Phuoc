import blynklib
import RPi.GPIO as GPIO
import time

# --- CẤU HÌNH ---
BLYNK_AUTH_TOKEN = "Ii8HYbZFetp15zyfJ47NGgeCE0ErknkO"
LED_PIN = 17  # Chân GPIO 17 (Physical Pin 11)

# Thiết lập GPIO
GPIO.setmode(GPIO.BCM)
GPIO.setup(LED_PIN, GPIO.OUT)
GPIO.output(LED_PIN, GPIO.LOW) # Mặc định tắt LED khi khởi động

# Khởi tạo Blynk
blynk = blynklib.Blynk(BLYNK_AUTH_TOKEN)

# Hàm xử lý khi nhấn Switch trên Blynk (V0)
@blynk.on("V0")
def v0_write_handler(value):
    # value là một list, lấy phần tử đầu tiên
    state = int(value[0])
    if state == 1:
        GPIO.output(LED_PIN, GPIO.HIGH)
        print("Trạng thái: LED BẬT")
    else:
        GPIO.output(LED_PIN, GPIO.LOW)
        print("Trạng thái: LED TẮT")

print("Đang kết nối tới Blynk Cloud...")

# Vòng lặp chính
try:
    while True:
        blynk.run()
except KeyboardInterrupt:
    print("\nĐang đóng chương trình...")
    GPIO.cleanup()
