import blynklib
from gpiozero import LED
import time

# --- CẤU HÌNH ---
BLYNK_AUTH_TOKEN = "Ii8HYbZFetp15zyfJ47NGgeCE0ErknkO"
led = LED(17) 

# Khởi tạo Blynk
blynk = blynklib.Blynk(BLYNK_AUTH_TOKEN)

# Thay vì dùng decorator @blynk.on, ta dùng phương thức này:
@blynk.handle_event('write V0')
def v0_write_handler(pin, value):
    state = int(value[0])
    if state == 1:
        led.on()
        print("Trạng thái: LED BẬT")
    else:
        led.off()
        print("Trạng thái: LED TẮT")

print("Đang kết nối tới Blynk Cloud...")

# Vòng lặp chính
try:
    while True:
        blynk.run()
except KeyboardInterrupt:
    print("\nĐang đóng chương trình...")
